# ── Supabase (banco Next.js) ─────────────────────────────────────────────────
# Transaction mode via PgBouncer (porta 6543) — para queries da aplicação
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"
# Session mode (porta 5432) — para prisma migrate dev/deploy
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── Next.js ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-com-openssl-rand-base64-32"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Evolution API (WhatsApp — VPS Hostinger, SQLite local) ───────────────────
EVOLUTION_API_URL="http://seu-ip-vps:8080"
EVOLUTION_API_GLOBAL_TOKEN="seu-token-global-aqui"

# ── n8n (Automation — VPS Hostinger, SQLite local) ───────────────────────────
N8N_WEBHOOK_URL="http://seu-ip-vps:5678"
N8N_API_KEY="sua-api-key-n8n"
N8N_ENCRYPTION_KEY="chave-de-32-chars-minimo-gerada-com-openssl"
NEXTJS_INTERNAL_API_SECRET="secret-para-chamadas-internas-next-n8n"

# ── LLM Providers ────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GROQ_API_KEY="gsk_..."
LLM_PROVIDER_SDR="openai"
LLM_MODEL_SDR="gpt-4o-mini"
LLM_PROVIDER_VENDEDOR="openai"
LLM_MODEL_VENDEDOR="gpt-4o"
LLM_PROVIDER_INTELLIGENCE="openai"
LLM_MODEL_INTELLIGENCE="gpt-4o-mini"
